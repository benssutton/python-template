# Copy to .env and fill in. .env is gitignored.

# OS Data Hub key — https://osdatahub.os.uk
# A free OS OpenData plan is sufficient. Used for OS Names (geocoder),
# OS Linked Identifiers and OS Downloads. We do NOT call OS Places API
# (Premium-only). UPRN -> coords goes via the OS Open UPRN bulk import,
# loaded once via `python bootstrap_os_open_uprn.py`.
OS_API_KEY=

# EPC Open Data — https://epc.opendatacommunities.org/  (free, registration only)
EPC_EMAIL=
EPC_API_KEY=

# Postgres (asyncpg driver is added by settings.database_url)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=planning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Behaviour
DEFAULT_RADIUS_M=250
CRAWL_CACHE_TTL_DAYS=30
# Relaunch the crawler's Chromium every N postcodes (0 = never; it still
# self-heals if the browser dies). Bounds memory on long wide crawls.
CRAWL_BROWSER_RECYCLE_EVERY=50
PLAYWRIGHT_HEADLESS=false

# ----- Document pipeline -----
DOCUMENTS_ROOT=data/documents
DOWNLOAD_CONCURRENCY=4
DOWNLOAD_TIMEOUT_SECONDS=60
INDEX_CONCURRENCY=2
CHUNK_CHARS=2000
OVERLAP_CHARS=200

# ----- Embeddings (Ollama) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_CONCURRENCY=4
